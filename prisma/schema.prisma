generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[]
}

model Hashtag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[] @relation("HashtagToPost")
}

model Post {
  id            Int       @id @default(autoincrement())
  kabupaten     String
  locationId    Int
  province      String    @default("Bali")
  title         String
  slug          String?   @unique
  tagline       String
  likes         Int       @default(0)
  saves         Int       @default(0)
  views         Int       @default(0)
  bestTime      String
  howToGet      String
  cost          String
  body          String
  venue         String?
  guidePdfUrl   String?
  lemonSqueezyUrl String?
  guidePrice    String?
  googleMapsUrl String?
  isDraft       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  images        Image[]
  location      Location  @relation(fields: [locationId], references: [id])
  hashtags      Hashtag[] @relation("HashtagToPost")
}

model Image {
  id     Int    @id @default(autoincrement())
  url    String
  postId Int
  post   Post   @relation(fields: [postId], references: [id])
}
