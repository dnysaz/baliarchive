generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hashtag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[] @relation("HashtagToPost")
}

model Regency {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id              Int       @id @default(autoincrement())
  regencyId       Int       // FK to Regency
  province        String    @default("Bali")
  title           String
  slug            String?   @unique
  tagline         String
  likes           Int       @default(0)
  saves           Int       @default(0)
  views           Int       @default(0)
  bestTime        String
  howToGet        String
  cost            String
  body            String
  venue           String?
  guidePdfUrl     String?
  guidePrice      String?
  googleMapsUrl   String?
  isDraft         Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lemonSqueezyUrl String?
  isAd            Boolean   @default(false)
  advertiserName  String?
  images          Image[]
  regency         Regency   @relation(fields: [regencyId], references: [id])
  hashtags        Hashtag[] @relation("HashtagToPost")
}


model Image {
  id     Int    @id @default(autoincrement())
  url    String
  type   String @default("IMAGE") // New: supports IMAGE or VIDEO
  postId Int
  post   Post   @relation(fields: [postId], references: [id])
}
model SiteSettings {
  id          Int      @id @default(1)
  title       String?
  description String?
  keywords    String?
  ogImage     String?
  favicon     String?
  aboutTitle  String   @default("Welcome to Bali Archive")
  aboutContent String  @default("")
  termsTitle  String   @default("Terms & Conditions")
  termsContent String  @default("")
  contactTitle String  @default("Contact")
  contactContent String @default("")
  updatedAt   DateTime @updatedAt
}

model Message {
  id        Int      @id @default(autoincrement())
  email     String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

