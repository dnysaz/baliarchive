// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  posts     Post[]
}

model Hashtag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  posts     Post[]
}

model Post {
  id         Int      @id @default(autoincrement())
  kabupaten  String   
  location   Location @relation(fields: [locationId], references: [id])
  locationId Int
  province   String   @default("Bali")
  category   String   
  hashtag    Hashtag  @relation(fields: [hashtagId], references: [id])
  hashtagId  Int
  title      String
  tagline    String
  likes      Int      @default(0)
  saves      Int      @default(0)
  bestTime   String
  howToGet   String
  cost       String
  body       String
  venue      String?
  guidePdfUrl String?
  guidePrice  String?
  images     Image[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Image {
  id     Int    @id @default(autoincrement())
  url    String
  post   Post   @relation(fields: [postId], references: [id])
  postId Int
}
