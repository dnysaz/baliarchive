# Ini adalah template environment (variabel konfigurasi).
# Salin file ini menjadi ".env" lalu isi nilai-nilainya sesuai dengan pengaturan hosting Anda.

# Konfigurasi Database (Contoh menggunakan SQLite untuk lokal)
# Jika produksi/Vercel, gunakan PostgreSQL: "postgresql://user:password@host:port/database"
DATABASE_URL="file:./dev.db"

# URL Utama Aplikasi 
# Ganti dengan nama domain saat online (misal: "https://baliarchive.com")
NEXTAUTH_URL="https://baliarchive.com"

# Gembok Rahasia NextAuth. HARUS DIUBAH!
# Eksekusi `openssl rand -base64 32` di terminal untuk membuat token yang kuat
NEXTAUTH_SECRET="your-super-secret-key-here"

# Akun Admin Utama (Data Ini Akan Masuk Pertama Kali Jika "npm run seed" Dieksekusi)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME=""